generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  passwordHash String?       // Pode ser null se logar com Google/Facebook
  name         String
  provider     String        @default("email") // "email", "google", "facebook"
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  transactions Transaction[]
  investments  Investment[]
}

model Transaction {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  type        String   // "INCOME" | "EXPENSE"
  amount      Float
  category    String   // "Salário", "Alimentação", "Transporte", etc
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Investment {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  type        String   // "RESERVA", "ACAO", "CDB", "FII"
  amount      Float
  assetSymbol String?  // Ex: "PETR4", "Tesouro Selic"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MarketAsset {
  id         String   @id @default(uuid())
  symbol     String   @unique
  name       String
  price      Float
  changePerc Float?   // Variação % diária
  updatedAt  DateTime @updatedAt
}

model EconomicIndicator {
  id        String   @id @default(uuid())
  name      String   @unique // "IPCA", "SELIC", "USD_BRL", "EUR_BRL"
  value     Float
  updatedAt DateTime @updatedAt
}
